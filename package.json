{
  "name": "react-example",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev --workspace=server",
    "build": "npm run build --workspaces",
    "build:client": "npm run build --workspace=client",
    "build:server": "npm run build --workspace=server",
    "start": "npm start --workspace=server",
    "clean": "rm -rf dist server.js client/dist server/dist",
    "lint": "npm run lint --workspaces --if-present"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.16.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.3.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "joi": "^18.2.1",
    "lucide-react": "^0.546.0",
    "mongoose": "^9.6.2",
    "motion": "^12.23.24",
    "react": "^18.3.1",
    "@hello-pangea/dnd": "^17.0.0",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^22.14.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
